<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <!-- App title bar -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@color/toolbar_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Spectrum view — takes 42% of total screen height -->
    <com.traillife.eqcalibration.SpectrumView
        android:id="@+id/spectrumView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/spectrum_bg"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.42"
        app:layout_constraintVertical_bias="0"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Status text sits below the spectrum view -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/status_stopped"
        android:textColor="@color/status_stopped"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/spectrumView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Button row: Start/Stop + Hold -->
    <LinearLayout
        android:id="@+id/buttonBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/toolbar_bg"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/btn_start"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/btn_start"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btnHold"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/btn_hold"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/btn_hold"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- "HOLD ACTIVE" indicator banner (hidden by default) -->
    <TextView
        android:id="@+id/tvHoldStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/hold_active"
        android:textColor="@color/hold_active_text"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/hold_active_bg"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/buttonBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider before EQ table -->
    <View
        android:id="@+id/tableHeaderDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tvHoldStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "EQ Recommendations" section title -->
    <TextView
        android:id="@+id/tvEqTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/eq_recommendations_title"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/tableHeaderDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable EQ table — fills remaining space to bottom of screen -->
    <ScrollView
        android:id="@+id/scrollEqTable"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvEqTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TableLayout
            android:id="@+id/tableEq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:padding="4dp" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
